# Supabase Configuration
# Get these from: https://app.supabase.com → Your Project → Settings → API

# Required: Your Supabase project URL
#NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Required: Service Role Key (preferred - bypasses RLS)
# Get from: Settings → API → service_role key (secret)
#SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Anon Key (fallback if service role key not provided)
# Get from: Settings → API → anon public key
#NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# HuggingFace API Configuration (for CV parsing with AI)
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# Optional: HuggingFace Model (defaults to google/gemma-2b-it)
HUGGINGFACE_MODEL=google/gemma-2b-it

# JWT Configuration (for authentication)
# Generate a secure key: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # Optional, defaults to 1440 (24 hours)
